digraph G {
    dpi=300;
    rankdir=TB;
    nodesep=0.75;
    ranksep=0.75;
    node [shape=box, style="filled,solid", fontname="Arial", fontsize=10, margin="0.2,0.1"];
    edge [fontname="Arial", fontsize=9, color="#333333"];

    // Level 1: Data Sources
    {
        rank=same;
        D1 [label=<<B>MIMIC-IV Structured Tables</B><BR/><FONT POINT-SIZE="8">admissions, patients, DRG codes, transfers, vitals, labs</FONT>>, fillcolor="#e6f2ff", color="#0066cc"];
        D2 [label=<<B>Clinical Notes (MIMIC-IV-Note)</B><BR/><FONT POINT-SIZE="8">discharge summaries, radiology reports</FONT>>, fillcolor="#e6ffe6", color="#009933"];
    }

    // Level 2: Processing
    {
        rank=same;
        P1 [label=<<B>Structured Feature Engineering</B><BR/><FONT POINT-SIZE="8">675 candidates &rarr; 128 selected</FONT>>, fillcolor="#e6f2ff", color="#0066cc"];
        P2 [label=<<B>ClinicalT5 Embedding</B><BR/><FONT POINT-SIZE="8">200-word chunking, mean pooling &rarr; 512-dim &rarr; PCA</FONT>>, fillcolor="#e6ffe6", color="#009933"];
    }

    // Level 3: Models
    {
        rank=same;
        M1 [label=<<B>ACAGN-Base</B><BR/><FONT POINT-SIZE="8">LightGBM, XGBoost, CatBoost, LR Meta-learner, Isotonic Calib.</FONT>>, fillcolor="#e6f2ff", color="#0066cc"];
        
        subgraph cluster_novel {
            label="Novel Contribution";
            fontname="Arial";
            fontsize=9;
            fontcolor="#cc5200";
            color="#cc5200";
            style="dashed";
            fillcolor="#fffaf6";
            bgcolor="#fffaf6"; /* some Graphviz versions use bgcolor for cluster */
            M2 [label=<<B>ACAGN-Gate</B><BR/><FONT POINT-SIZE="8">Gate Network + MLP Classifier</FONT>>, fillcolor="#fff0e6", color="#cc5200", style="filled,solid"];
        }
    }

    // Level 4: Combination
    {
        rank=same;
        H1 [label=<<B>ACAGN-Hybrid</B><BR/><FONT POINT-SIZE="8">0.5 &times; Base + 0.5 &times; Gate</FONT>>, fillcolor="#fff0e6", color="#cc5200"];
    }

    // Level 5: Outputs
    {
        rank=same;
        O1 [label=<<B>Risk Score 0&ndash;1</B><BR/><FONT POINT-SIZE="8">Threshold Selection, SHAP Explanation, Gate-Weight Explanation</FONT>>, fillcolor="#fff0e6", color="#cc5200"];
    }

    // Connections
    D1 -> P1 [label=" raw structured data ", labelfontname="Arial", fontsize=9];
    D2 -> P2 [label=" raw clinical text ", labelfontname="Arial", fontsize=9];

    P1 -> M1 [label=" 128 structured features ", fontsize=9];
    P1 -> M2 [label=" 128 structured features ", fontsize=9];
    P2 -> M2 [label=" 512-dim vector ", fontsize=9];

    M1 -> H1 [label=" base-risk score ", fontsize=9];
    M2 -> H1 [label=" calibrated probability ", fontsize=9];

    H1 -> O1 [label=" final probability ", fontsize=9];
}
