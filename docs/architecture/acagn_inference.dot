digraph ACAGN_Gate_Detail {
  graph [
    rankdir=LR,
    fontsize=12,
    fontname="Helvetica",
    labelloc="t",
    label="Diagram 2 — ACAGN-Gate Detail (text-guided feature gating)",
    bgcolor="white",
    pad=0.25,
    nodesep=0.5,
    ranksep=0.55
  ];

  edge [color="black", arrowsize=0.8, penwidth=1.0, fontname="Helvetica", fontsize=10];
  node [
    shape=box,
    style="filled",
    color="black",
    fontname="Helvetica",
    fontsize=11,
    margin="0.08,0.06",
    fixedsize=true,
    width=2.7,
    height=0.85
  ];

  // Inputs
  x_struct [
    fillcolor="#DBEAFE",
    label=<
      <B>x_structured</B><BR/>
      <FONT POINT-SIZE="10">160-dim vector</FONT>
    >
  ];

  e_text [
    fillcolor="#DCFCE7",
    label=<
      <B>e_text</B><BR/>
      <FONT POINT-SIZE="10">515-dim vector</FONT>
    >
  ];

  // Gate network G (layers explicitly shown)
  g_lin1 [
    fillcolor="#DCFCE7",
    label=<
      <B>Linear</B><BR/>
      <FONT POINT-SIZE="10">515 → 256</FONT>
    >
  ];
  g_relu [
    fillcolor="#DCFCE7",
    label=<
      <B>ReLU</B><BR/>
      <FONT POINT-SIZE="10">activation</FONT>
    >
  ];
  g_lin2 [
    fillcolor="#DCFCE7",
    label=<
      <B>Linear</B><BR/>
      <FONT POINT-SIZE="10">256 → 160</FONT>
    >
  ];
  g_sig [
    fillcolor="#DCFCE7",
    label=<
      <B>Sigmoid</B><BR/>
      <FONT POINT-SIZE="10">σ(·)</FONT>
    >
  ];

  g_vec [
    fillcolor="#DCFCE7",
    label=<
      <B>g</B><BR/>
      <FONT POINT-SIZE="10">(0,1)^160</FONT>
    >
  ];

  // Multiplication centerpiece
  mult [
    shape=circle,
    fixedsize=true,
    width=0.75,
    height=0.75,
    penwidth=1.3,
    fillcolor="#FFEDD5",
    label=<
      <FONT POINT-SIZE="22"><B>⊙</B></FONT>
    >
  ];

  eq_box [
    fillcolor="white",
    fixedsize=false,
    label=<
      <B>Gate Equations</B><BR/>
      <FONT POINT-SIZE="10">g=σ(W₂·ReLU(W₁·e_text)); x_gated=g⊙x_structured</FONT>
    >
  ];

  x_gated [
    fillcolor="#DBEAFE",
    label=<
      <B>x_gated</B><BR/>
      <FONT POINT-SIZE="10">g ⊙ x_structured</FONT>
    >
  ];

  concat [
    fillcolor="#FFEDD5",
    label=<
      <B>Concatenate</B><BR/>
      <FONT POINT-SIZE="10">675-dim fused</FONT>
    >
  ];

  // Classifier head (layers explicitly shown, each in its own box)
  fc1 [
    fillcolor="#FFEDD5",
    label=<
      <B>FC1</B><BR/>
      <FONT POINT-SIZE="10">675 → 512, BN, ReLU, Drop 0.3</FONT>
    >
  ];
  fc2 [
    fillcolor="#FFEDD5",
    label=<
      <B>FC2</B><BR/>
      <FONT POINT-SIZE="10">512 → 256, BN, ReLU, Drop 0.3</FONT>
    >
  ];
  fc3 [
    fillcolor="#FFEDD5",
    label=<
      <B>FC3</B><BR/>
      <FONT POINT-SIZE="10">256 → 128, ReLU, Drop 0.2</FONT>
    >
  ];
  out [
    fillcolor="#FFEDD5",
    label=<
      <B>Output</B><BR/>
      <FONT POINT-SIZE="10">128 → 1, Sigmoid</FONT>
    >
  ];

  yhat [
    fillcolor="#FFEDD5",
    label=<
      <B>ŷ</B><BR/>
      <FONT POINT-SIZE="10">readmission risk</FONT>
    >
  ];

  // Flow (all arrows labeled; keep labels short)
  e_text -> g_lin1 [label="515-dim"];
  g_lin1 -> g_relu [label="hidden"];
  g_relu -> g_lin2 [label="hidden"];
  g_lin2 -> g_sig  [label="logits"];
  g_sig  -> g_vec  [label="gate vec"];

  x_struct -> mult [label="160-dim"];
  g_vec    -> mult [label="gate weights"];
  mult     -> x_gated [label="element-wise"];

  x_gated -> concat [label="x_gated"];
  e_text  -> concat [label="e_text"];

  concat -> fc1 [label="675-dim"];
  fc1 -> fc2 [label="512"];
  fc2 -> fc3 [label="256"];
  fc3 -> out [label="128"];
  out -> yhat [label="risk p̂"];

  // Place equations near the gate mechanism without changing main flow
  g_vec -> eq_box [style=dashed, arrowhead=none, constraint=false];
}
